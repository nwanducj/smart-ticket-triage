{
  "name": "smart-triage-backend",
  "version": "1.0.0",
  "description": "Smart Triage AI-powered ticketing system — backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "seed": "ts-node seeds/seed.ts",
    "lint": "tsc --noEmit"
